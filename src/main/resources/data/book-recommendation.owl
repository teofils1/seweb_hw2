<?xml version="1.0" encoding="UTF-8"?>

<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:br="http://example.org/book-recommendation#"
    xml:base="http://example.org/book-recommendation">

    <!--
        Book Recommendation Ontology
        Base namespace: http://example.org/book-recommendation#

        Recommendation rule used by the application:
        A book is recommended for a user when:
        1. The book has at least one theme equal to the user's preferred theme.
        2. The book's suitable reading level equals the user's reading level.

        In the web application, this rule can be implemented with SPARQL/Jena.
    -->

    <!-- Ontology declaration -->
    <owl:Ontology rdf:about="http://example.org/book-recommendation">
        <rdfs:label>Book Recommendation Ontology</rdfs:label>
        <rdfs:comment>
            OWL ontology for a semantic web book recommendation system using users,
            books, themes, reading levels and authors.
        </rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Classes -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/book-recommendation#User">
        <rdfs:label>User</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/book-recommendation#Book">
        <rdfs:label>Book</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/book-recommendation#Theme">
        <rdfs:label>Theme</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/book-recommendation#ReadingLevel">
        <rdfs:label>Reading Level</rdfs:label>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/book-recommendation#Author">
        <rdfs:label>Author</rdfs:label>
    </owl:Class>

    <!-- ===================== -->
    <!-- Object properties -->
    <!-- ===================== -->

    <owl:ObjectProperty rdf:about="http://example.org/book-recommendation#hasPreferredTheme">
        <rdfs:label>has preferred theme</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/book-recommendation#User"/>
        <rdfs:range rdf:resource="http://example.org/book-recommendation#Theme"/>
        <rdfs:comment>Connects a user to the theme they prefer.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/book-recommendation#hasReadingLevel">
        <rdfs:label>has reading level</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/book-recommendation#User"/>
        <rdfs:range rdf:resource="http://example.org/book-recommendation#ReadingLevel"/>
        <rdfs:comment>Connects a user to their reading level.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/book-recommendation#hasTheme">
        <rdfs:label>has theme</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:range rdf:resource="http://example.org/book-recommendation#Theme"/>
        <rdfs:comment>Connects a book to one of its themes or genres.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/book-recommendation#suitableForLevel">
        <rdfs:label>suitable for level</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:range rdf:resource="http://example.org/book-recommendation#ReadingLevel"/>
        <rdfs:comment>Connects a book to the reading level it is suitable for.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/book-recommendation#hasAuthor">
        <rdfs:label>has author</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:range rdf:resource="http://example.org/book-recommendation#Author"/>
        <rdfs:comment>Connects a book to its author.</rdfs:comment>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/book-recommendation#recommendedFor">
        <rdfs:label>recommended for</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:range rdf:resource="http://example.org/book-recommendation#User"/>
        <rdfs:comment>
            Connects a book to a user when the recommendation rule is satisfied.
            This relation can be computed using SPARQL/Jena in the web application.
        </rdfs:comment>
    </owl:ObjectProperty>

    <!-- ===================== -->
    <!-- Datatype properties -->
    <!-- ===================== -->

    <owl:DatatypeProperty rdf:about="http://example.org/book-recommendation#title">
        <rdfs:label>title</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/book-recommendation#name">
        <rdfs:label>name</rdfs:label>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- ===================== -->
    <!-- Reading level individuals -->
    <!-- ===================== -->

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Beginner">
        <rdf:type rdf:resource="http://example.org/book-recommendation#ReadingLevel"/>
        <rdfs:label>Beginner</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Beginner</br:name>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Intermediate">
        <rdf:type rdf:resource="http://example.org/book-recommendation#ReadingLevel"/>
        <rdfs:label>Intermediate</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Intermediate</br:name>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Advanced">
        <rdf:type rdf:resource="http://example.org/book-recommendation#ReadingLevel"/>
        <rdfs:label>Advanced</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Advanced</br:name>
    </owl:NamedIndividual>

    <!-- ===================== -->
    <!-- Theme individuals -->
    <!-- ===================== -->

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Science_Fiction">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Theme"/>
        <rdfs:label>Science Fiction</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Science Fiction</br:name>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Fantasy">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Theme"/>
        <rdfs:label>Fantasy</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Fantasy</br:name>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Mystery">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Theme"/>
        <rdfs:label>Mystery</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Mystery</br:name>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Murder">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Theme"/>
        <rdfs:label>Murder</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Murder</br:name>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Magic">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Theme"/>
        <rdfs:label>Magic</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Magic</br:name>
    </owl:NamedIndividual>

    <!-- ===================== -->
    <!-- Author individuals -->
    <!-- ===================== -->

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Frank_Herbert">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Author"/>
        <rdfs:label>Frank Herbert</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Frank Herbert</br:name>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Alex_Michaelides">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Author"/>
        <rdfs:label>Alex Michaelides</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alex Michaelides</br:name>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Suzanne_Collins">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Author"/>
        <rdfs:label>Suzanne Collins</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Suzanne Collins</br:name>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#J_K_Rowling">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Author"/>
        <rdfs:label>J. K. Rowling</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">J. K. Rowling</br:name>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Isaac_Asimov">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Author"/>
        <rdfs:label>Isaac Asimov</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Isaac Asimov</br:name>
    </owl:NamedIndividual>
    
    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Carolyn_Keene">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Author"/>
        <rdfs:label>Carolyn Keene</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Carolyn Keene</br:name>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Gillian_Flynn">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Author"/>
        <rdfs:label>Gillian Flynn</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gillian Flynn</br:name>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#George_R_R_Martin">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Author"/>
        <rdfs:label>George R. R. Martin</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">George R. R. Martin</br:name>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Andy_Weir">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Author"/>
        <rdfs:label>Andy Weir</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Andy Weir</br:name>
    </owl:NamedIndividual>

    <!-- ===================== -->
    <!-- User individuals -->
    <!-- ===================== -->

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Alice">
        <rdf:type rdf:resource="http://example.org/book-recommendation#User"/>
        <rdfs:label>Alice</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Alice</br:name>
        <br:hasReadingLevel rdf:resource="http://example.org/book-recommendation#Intermediate"/>
        <br:hasPreferredTheme rdf:resource="http://example.org/book-recommendation#Science_Fiction"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Bob">
        <rdf:type rdf:resource="http://example.org/book-recommendation#User"/>
        <rdfs:label>Bob</rdfs:label>
        <br:name rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Bob</br:name>
        <br:hasReadingLevel rdf:resource="http://example.org/book-recommendation#Beginner"/>
        <br:hasPreferredTheme rdf:resource="http://example.org/book-recommendation#Mystery"/>
    </owl:NamedIndividual>

    <!-- ===================== -->
    <!-- Book individuals -->
    <!-- ===================== -->

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Dune">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:label>Dune</rdfs:label>
        <br:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Dune</br:title>
        <br:hasAuthor rdf:resource="http://example.org/book-recommendation#Frank_Herbert"/>
        <br:hasTheme rdf:resource="http://example.org/book-recommendation#Science_Fiction"/>
        <br:hasTheme rdf:resource="http://example.org/book-recommendation#Fantasy"/>
        <br:suitableForLevel rdf:resource="http://example.org/book-recommendation#Advanced"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#The_Silent_Patient">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:label>The Silent Patient</rdfs:label>
        <br:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The Silent Patient</br:title>
        <br:hasAuthor rdf:resource="http://example.org/book-recommendation#Alex_Michaelides"/>
        <br:hasTheme rdf:resource="http://example.org/book-recommendation#Mystery"/>
        <br:hasTheme rdf:resource="http://example.org/book-recommendation#Murder"/>
        <br:suitableForLevel rdf:resource="http://example.org/book-recommendation#Intermediate"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Hunger_Games">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:label>Hunger Games</rdfs:label>
        <br:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Hunger Games</br:title>
        <br:hasAuthor rdf:resource="http://example.org/book-recommendation#Suzanne_Collins"/>
        <br:hasTheme rdf:resource="http://example.org/book-recommendation#Science_Fiction"/>
        <br:hasTheme rdf:resource="http://example.org/book-recommendation#Fantasy"/>
        <br:suitableForLevel rdf:resource="http://example.org/book-recommendation#Beginner"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Harry_Potter">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:label>Harry Potter</rdfs:label>
        <br:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Harry Potter</br:title>
        <br:hasAuthor rdf:resource="http://example.org/book-recommendation#J_K_Rowling"/>
        <br:hasTheme rdf:resource="http://example.org/book-recommendation#Fantasy"/>
        <br:hasTheme rdf:resource="http://example.org/book-recommendation#Magic"/>
        <br:suitableForLevel rdf:resource="http://example.org/book-recommendation#Beginner"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Foundation">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:label>Foundation</rdfs:label>
        <br:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Foundation</br:title>
        <br:hasAuthor rdf:resource="http://example.org/book-recommendation#Isaac_Asimov"/>
        <br:hasTheme rdf:resource="http://example.org/book-recommendation#Science_Fiction"/>
        <br:suitableForLevel rdf:resource="http://example.org/book-recommendation#Intermediate"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Nancy_Drew">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:label>Nancy Drew</rdfs:label>
        <br:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Nancy Drew</br:title>
        <br:hasAuthor rdf:resource="http://example.org/book-recommendation#Carolyn_Keene"/>
        <br:hasTheme rdf:resource="http://example.org/book-recommendation#Mystery"/>
        <br:suitableForLevel rdf:resource="http://example.org/book-recommendation#Beginner"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#Gone_Girl">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:label>Gone Girl</rdfs:label>
        <br:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">Gone Girl</br:title>
        <br:hasAuthor rdf:resource="http://example.org/book-recommendation#Gillian_Flynn"/>
        <br:hasTheme rdf:resource="http://example.org/book-recommendation#Murder"/>
        <br:hasTheme rdf:resource="http://example.org/book-recommendation#Mystery"/>
        <br:suitableForLevel rdf:resource="http://example.org/book-recommendation#Intermediate"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#A_Game_Of_Thrones">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:label>A Game of Thrones</rdfs:label>
        <br:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A Game of Thrones</br:title>
        <br:hasAuthor rdf:resource="http://example.org/book-recommendation#George_R_R_Martin"/>
        <br:hasTheme rdf:resource="http://example.org/book-recommendation#Fantasy"/>
        <br:suitableForLevel rdf:resource="http://example.org/book-recommendation#Advanced"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/book-recommendation#The_Martian">
        <rdf:type rdf:resource="http://example.org/book-recommendation#Book"/>
        <rdfs:label>The Martian</rdfs:label>
        <br:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">The Martian</br:title>
        <br:hasAuthor rdf:resource="http://example.org/book-recommendation#Andy_Weir"/>
        <br:hasTheme rdf:resource="http://example.org/book-recommendation#Science_Fiction"/>
        <br:suitableForLevel rdf:resource="http://example.org/book-recommendation#Advanced"/>
    </owl:NamedIndividual>

</rdf:RDF>
